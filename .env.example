# 服务端口
PORT=3000

# 定时任务 cron 表达式（默认每天 16:00，北京时间）
CRON_SCHEDULE=0 16 * * *
TZ=Asia/Shanghai

# Cursor CLI 认证（用于生成分析报告）
# 在 https://cursor.com/settings 获取 API Key
CURSOR_API_KEY=crsr_728eab8631eb4865b1663ee9d32baae8e1332ab5ea3254d220194721e390eb2a

# PostgreSQL 连接串
DATABASE_URL=postgresql://ashare:ashare@localhost:5432/ashare_report

# 是否启用定时任务（设为 false 可仅作为 Web 展示服务）
ENABLE_SCHEDULER=true
