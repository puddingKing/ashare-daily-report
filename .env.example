# 服务端口
PORT=3000

# 定时任务 cron 表达式（默认每天 8:00，北京时间）
CRON_SCHEDULE=0 8 * * *
TZ=Asia/Shanghai

# Cursor CLI 认证（用于生成分析报告）
# 在 https://cursor.com/settings 获取 API Key
CURSOR_API_KEY=

# PostgreSQL 连接串
DATABASE_URL=postgresql://ashare:ashare@localhost:5432/ashare_report

# 是否启用定时任务（设为 false 可仅作为 Web 展示服务）
ENABLE_SCHEDULER=true
